{
  "name": "lunchflow-app",
  "version": "1.0.0",
  "main": "index.ts",
  "dependencies": {
    "@expo/vector-icons": "^15.1.1",
    "@react-native-async-storage/async-storage": "2.2.0",
    "@react-navigation/bottom-tabs": "^7.18.0",
    "@react-navigation/native": "^7.3.1",
    "@react-navigation/native-stack": "^7.17.3",
    "expo": "~56.0.12",
    "expo-camera": "~56.0.8",
    "expo-constants": "~56.0.18",
    "expo-device": "~56.0.4",
    "expo-linear-gradient": "^56.0.4",
    "expo-location": "~56.0.18",
    "expo-notifications": "~56.0.18",
    "expo-splash-screen": "~56.0.10",
    "expo-status-bar": "~56.0.4",
    "firebase": "^12.14.0",
    "react": "19.2.3",
    "react-dom": "19.2.3",
    "react-native": "0.85.3",
    "react-native-safe-area-context": "~5.7.0",
    "react-native-screens": "^4.25.2",
    "react-native-svg": "15.15.4",
    "react-native-web": "^0.21.2",
    "react-qr-code": "^2.2.0"
  },
  "devDependencies": {
    "@types/react": "~19.2.2",
    "typescript": "~6.0.3"
  },
  "scripts": {
    "start": "expo start",
    "android": "expo run:android",
    "ios": "expo run:ios",
    "web": "expo start --web --port 8081",
    "build:web": "expo export -p web",
    "build:apk": "expo prebuild --platform android --no-install && cd android && gradlew.bat assembleRelease -PreactNativeArchitectures=arm64-v8a",
    "deploy": "npm run build:web && firebase deploy --only hosting",
    "deploy:all": "npm run build:web && firebase deploy",
    "deploy:functions": "cd functions && npm run build && cd .. && firebase deploy --only functions"
  },
  "private": true
}

{
  "expo": {
    "name": "LunchFlow",
    "slug": "lunchflow",
    "owner": "thisai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "splash": {
      "image": "./assets/splash-icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#FDF2F8"
    },
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Scan customer QR codes to verify pickup.",
        "NSLocationWhenInUseUsageDescription": "Share live delivery location with customers and admin."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#141428",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.thisai.lunchbox",
      "googleServicesFile": "./google-services.json",
      "permissions": [
        "POST_NOTIFICATIONS",
        "ACCESS_COARSE_LOCATION",
        "ACCESS_FINE_LOCATION",
        "CAMERA"
      ]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FFD6E8",
          "defaultChannel": "order-updates"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow LunchFlow to share your live delivery location."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow LunchFlow to scan pickup QR codes."
        }
      ],
      [
        "expo-splash-screen",
        {
          "image": "./assets/splash-icon.png",
          "imageWidth": 132,
          "resizeMode": "contain",
          "backgroundColor": "#FDF2F8"
        }
      ]
    ],
    "extra": {
      "googleMapsApiKey": ""
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}

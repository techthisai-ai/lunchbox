{
  "expo": {
    "name": "LunchFlow",
    "slug": "lunchflow",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "light",
    "ios": {
      "supportsTablet": true,
      "infoPlist": {
        "NSCameraUsageDescription": "Scan customer QR codes to verify pickup.",
        "NSLocationWhenInUseUsageDescription": "Share live delivery location with customers and admin."
      }
    },
    "android": {
      "adaptiveIcon": {
        "backgroundColor": "#E6F4FE",
        "foregroundImage": "./assets/android-icon-foreground.png",
        "backgroundImage": "./assets/android-icon-background.png",
        "monochromeImage": "./assets/android-icon-monochrome.png"
      },
      "predictiveBackGestureEnabled": false,
      "package": "com.thisai.lunchbox",
      "permissions": ["POST_NOTIFICATIONS", "ACCESS_COARSE_LOCATION", "ACCESS_FINE_LOCATION", "CAMERA"]
    },
    "plugins": [
      [
        "expo-notifications",
        {
          "icon": "./assets/icon.png",
          "color": "#FFD6E8",
          "defaultChannel": "order-updates"
        }
      ],
      [
        "expo-location",
        {
          "locationWhenInUsePermission": "Allow LunchFlow to share your live delivery location."
        }
      ],
      [
        "expo-camera",
        {
          "cameraPermission": "Allow LunchFlow to scan pickup QR codes."
        }
      ]
    ],
    "extra": {
      "googleMapsApiKey": ""
    },
    "web": {
      "favicon": "./assets/favicon.png"
    }
  }
}
